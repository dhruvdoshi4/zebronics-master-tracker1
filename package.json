{
  "name": "zebronics-master-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "auth:check-env": "node scripts/check-env.mjs",
    "auth:ensure-user": "node scripts/ensure-auth-user.mjs",
    "seed:admin": "node scripts/seed-admin-workspace.mjs",
    "seed:dawg": "node scripts/seed-dawg-workspace.mjs",
    "seed:pravin": "node scripts/seed-pravin-workspace.mjs",
    "seed:rishabh": "node scripts/seed-rishabh-workspace.mjs",
    "validate:amazon-monitor-apr-so": "tsx scripts/validate-amazon-monitor-apr-so.ts",
    "verify:product-pricing": "node scripts/verify-product-pricing-formulas.mjs",
    "db:apply-category-monthly": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/apply-category-monthly-migration.ps1",
    "preview": "vite preview",
    "deploy:prod": "npm run build && npx vercel deploy --prod --yes"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "tsx": "^4.19.4",
    "vite": "^8.0.10"
  }
