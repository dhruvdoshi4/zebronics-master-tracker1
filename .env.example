# Vercel / local development environment variables
# Add these in .env.local for local and in Vercel project settings.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side only (scripts/ensure-auth-user.mjs). Never commit or expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

